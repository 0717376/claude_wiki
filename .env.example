# Пароль для входа в вики (единственный пользователь)
WIKI_PASSWORD=change-me

# Внешний порт фронтенда (необычный)
WIKI_PORT=8842

# Модель Claude: sonnet | opus | haiku
CLAUDE_MODEL=sonnet

# Telegram-бот (необязательно): чат с вики из Telegram, общая сессия с вебом.
# Токен от @BotFather. Пусто — бот выключен.
TELEGRAM_BOT_TOKEN=
# Кому из Telegram разрешён доступ (ID через запятую). Пусто — бот ответит твоим ID,
# чтобы ты вписал его сюда.
TELEGRAM_ALLOWED_IDS=

# Распознавание речи (необязательно): внешний ASR-эндпоинт. Пусто — голосовой ввод выключен.
ASR_UPSTREAM=
ASR_MODEL=gigaam-rnnt
